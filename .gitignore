########################################
# Dependencies (any depth)
########################################
node_modules/
bower_components/

########################################
# Environment variables & secrets
########################################
.env*
!.env.example
!.env.sample

########################################
# Logs (any depth)
########################################
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

########################################
# Build outputs / compiled files
########################################
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
coverage/

########################################
# Cache directories (any depth)
########################################
.cache/
.tmp/
.temp/
.parcel-cache/
.eslintcache

########################################
# OS / system files
########################################
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

########################################
# Editor / IDE files
########################################
.vscode/
.idea/
*.swp
*.swo
*.iml

########################################
# Package manager artifacts
########################################
.pnpm-store/
.yarn/
.yarn-cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

########################################
# Lock files (⚠️ usually KEEP these)
########################################
# Uncomment ONLY if you know what you're doing
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

########################################
# TypeScript
########################################
*.tsbuildinfo

########################################
# Python (in case any scripts exist)
########################################
__pycache__/
*.pyc
*.pyo

########################################
# Java / JVM
########################################
*.class
*.jar
*.war

########################################
# C / C++
########################################
*.o
*.out
*.exe

########################################
# Archives
########################################
*.zip
*.tar
*.gz
*.rar

########################################
# Temporary & backup files
########################################
*.tmp
*.temp
*.bak
*.old

########################################
# Uploads / user-generated content
########################################
uploads/

########################################
# Misc
########################################
*.pid
*.seed
*.pid.lock